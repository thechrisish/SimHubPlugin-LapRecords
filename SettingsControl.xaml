<UserControl x:Class="SimHubLapRecordPlugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:SimHubLapRecordPlugin"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <local:TyreCompoundConverter x:Key="TyreConverter" />
        <local:BindingProxy x:Key="TyreProxy" Data="{Binding Plugin.Settings.TyreCompoundDefinitions}" />
        <x:Array x:Key="TyreOptions" Type="system:String">
            <system:String>Soft</system:String>
            <system:String>Medium</system:String>
            <system:String>Hard</system:String>
            <system:String>Intermediate</system:String>
            <system:String>Wet</system:String>
            <system:String>Unknown</system:String>
        </x:Array>
        <x:Array x:Key="TrackStateOptions" Type="system:String">
            <system:String>Unknown</system:String>
            <system:String>Dry</system:String>
            <system:String>Intermediate</system:String>
            <system:String>Wet</system:String>
        </x:Array>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Lap Record Plugin" FontSize="20" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Refresh Data" Click="Refresh_Click" Margin="10,5" Padding="15,0" />
        </Grid>
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Lap Records">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Filter by Game:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <ComboBox Name="GameFilterCombo" Width="150" Margin="0,0,10,0" SelectionChanged="GameFilterCombo_SelectionChanged" />
                        <CheckBox Name="AutoFilterCheckbox" Content="Auto-Filter to Current Game" VerticalAlignment="Center" Checked="AutoFilterCheckbox_Changed" Unchecked="AutoFilterCheckbox_Changed" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl Name="TrackItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding TrackName}" IsExpanded="True" Margin="5">
                                        <DataGrid Name="LapRecordsGrid" ItemsSource="{Binding Records}" AutoGenerateColumns="False" Margin="5" Background="Transparent" RowBackground="Transparent" CanUserAddRows="False" CellEditEnding="LapRecordsGrid_CellEditEnding" Loaded="LapRecordsGrid_Loaded">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Date" Binding="{Binding RecordDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="80" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Game" Binding="{Binding GameName}" Width="80" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Car" Binding="{Binding CarName}" Width="*" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Class" Binding="{Binding CarClass}" Width="80" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Session" Binding="{Binding Session}" Width="100" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Fuel Level" Binding="{Binding DisplayFuel}" Width="80" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Track Temp" Binding="{Binding TrackTemperature}" Width="90" IsReadOnly="True" />
                                                <DataGridComboBoxColumn Header="Track State" SelectedItemBinding="{Binding TrackState}" ItemsSource="{StaticResource TrackStateOptions}" Width="100" />
                                                <DataGridTemplateColumn Header="Tyre" Width="160">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <UniformGrid Columns="2" Rows="2" Width="40" Height="40" VerticalAlignment="Center">
                                                                    <Border Background="{Binding TyreCompoundFL, Converter={StaticResource TyreConverter}, ConverterParameter='Color'}" BorderBrush="Black" BorderThickness="1,1,1,1">
                                                                        <TextBlock Text="{Binding TyreCompoundFL, Converter={StaticResource TyreConverter}, ConverterParameter='Text'}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold" FontSize="10" />
                                                                    </Border>
                                                                    <Border Background="{Binding TyreCompoundFR, Converter={StaticResource TyreConverter}, ConverterParameter='Color'}" BorderBrush="Black" BorderThickness="0,1,1,1">
                                                                        <TextBlock Text="{Binding TyreCompoundFR, Converter={StaticResource TyreConverter}, ConverterParameter='Text'}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                                                                    </Border>
                                                                    <Border Background="{Binding TyreCompoundRL, Converter={StaticResource TyreConverter}, ConverterParameter='Color'}" BorderBrush="Black" BorderThickness="1,0,1,1">
                                                                        <TextBlock Text="{Binding TyreCompoundRL, Converter={StaticResource TyreConverter}, ConverterParameter='Text'}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                                                                    </Border>
                                                                    <Border Background="{Binding TyreCompoundRR, Converter={StaticResource TyreConverter}, ConverterParameter='Color'}" BorderBrush="Black" BorderThickness="0,0,1,1">
                                                                        <TextBlock Text="{Binding TyreCompoundRR, Converter={StaticResource TyreConverter}, ConverterParameter='Text'}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                                                                    </Border>
                                                                </UniformGrid>
                                                                <ToggleButton Name="TyreEditToggle" Content="✎" Width="22" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Click="TyreEditToggle_Click"
                                                                              Tag="{Binding DataContext.Plugin.Settings.TyreCompoundDefinitions, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                <Popup Name="TyreEditPopup" StaysOpen="False" PlacementTarget="{Binding ElementName=TyreEditToggle}" Placement="Bottom">
                                                                    <Border Background="#2D2D2D" BorderBrush="#555" BorderThickness="1" Padding="10" CornerRadius="4">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                            </Grid.RowDefinitions>
                                                                            <TextBlock Text="Enter abbreviation (e.g. M, S, H)" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Foreground="#AAA" FontSize="10" FontStyle="Italic" Margin="0,0,0,8"/>
                                                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,5">
                                                                                <TextBlock Text="FL" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                                                <TextBox Width="60" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="14"
                                                                                         Text="{Binding TyreCompoundFL, Converter={StaticResource TyreConverter}, ConverterParameter='Text', UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                                         LostFocus="TyreTextBox_LostFocus" />
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,5">
                                                                                <TextBlock Text="FR" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                                                <TextBox Width="60" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="14"
                                                                                         Text="{Binding TyreCompoundFR, Converter={StaticResource TyreConverter}, ConverterParameter='Text', UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                                         LostFocus="TyreTextBox_LostFocus" />
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                                                                <TextBlock Text="RL" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                                                <TextBox Width="60" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="14"
                                                                                         Text="{Binding TyreCompoundRL, Converter={StaticResource TyreConverter}, ConverterParameter='Text', UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                                         LostFocus="TyreTextBox_LostFocus" />
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Row="2" Grid.Column="1">
                                                                                <TextBlock Text="RR" Foreground="#AAA" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                                                <TextBox Width="60" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="14"
                                                                                         Text="{Binding TyreCompoundRR, Converter={StaticResource TyreConverter}, ConverterParameter='Text', UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                                         LostFocus="TyreTextBox_LostFocus" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </Popup>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Laptime" Binding="{Binding LapTime, StringFormat=\{0:mm\\:ss\\.fff\}}" Width="100" IsReadOnly="True" />
                                                <DataGridTemplateColumn Width="70">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="Remove" Click="RemoveLapRecord_Click" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                    </DataGrid>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Car Overrides">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="5,10">
                        <TextBlock Text="Original Game Name:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <ComboBox Name="NewOriginalCarNameCombo" Width="150" Margin="0,0,10,0" IsEditable="True" />
                        <TextBlock Text="Display Name:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBox Name="NewOverrideCarName" Width="150" Margin="0,0,10,0" />
                        <Button Content="Add Override" Click="AddOverride_Click" Padding="10,5" />
                    </StackPanel>

                    <DataGrid Grid.Row="1" Name="OverridesGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="5" CellEditEnding="OverridesGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Original Car Name" Binding="{Binding OriginalCarName}" IsReadOnly="True" Width="*" />
                            <DataGridTextColumn Header="Overridden Name" Binding="{Binding OverriddenName}" Width="*" />
                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove" Click="RemoveOverride_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Track Overrides">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="5,8,5,4" TextWrapping="Wrap" FontStyle="Italic"
                               Text="Map a raw sim track name to a unified display name so laps from different sims (e.g. ACC and LMU) count toward the same record."/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,4,5,8">
                        <TextBlock Text="Sim Track Name:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <ComboBox Name="NewOriginalTrackNameCombo" Width="180" Margin="0,0,10,0" IsEditable="True" />
                        <TextBlock Text="Unified Name:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBox Name="NewUnifiedTrackName" Width="150" Margin="0,0,10,0" />
                        <Button Content="Add Override" Click="AddTrackOverride_Click" Padding="10,5" />
                    </StackPanel>

                    <DataGrid Grid.Row="2" Name="TrackOverridesGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="5" CellEditEnding="TrackOverridesGrid_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sim Track Name" Binding="{Binding OriginalTrackName}" IsReadOnly="True" Width="*" />
                            <DataGridTextColumn Header="Unified Name" Binding="{Binding UnifiedName}" Width="*" />
                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove" Click="RemoveTrackOverride_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="Column Visibility" Margin="0,0,0,10">
                            <WrapPanel Name="ColumnVisibilityPanel" Margin="5">
                                <!-- Checkboxes populated from code-behind -->
                            </WrapPanel>
                        </GroupBox>

                        <GroupBox Header="Custom Tyre Compounds" Margin="0,0,0,10">
                            <StackPanel Margin="5">
                                <TextBlock Text="Color field accepts valid color names (e.g. Red, Blue) or #HEX codes (e.g. #FF0000)." FontStyle="Italic" Margin="0,0,0,5" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBox Name="NewCompoundName" Width="100" Margin="0,0,5,0" Text="Name..." GotFocus="TextBox_GotFocus"/>
                                    <TextBox Name="NewCompoundAbbrev" Width="40" Margin="0,0,5,0" Text="Abbr" GotFocus="TextBox_GotFocus"/>
                                    <TextBox Name="NewCompoundColor" Width="60" Margin="0,0,5,0" Text="Color" GotFocus="TextBox_GotFocus"/>
                                    <Button Content="Add Compound" Click="AddCompound_Click" Padding="10,0" />
                                </StackPanel>
                                <ItemsControl Name="CompoundsListControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="100" VerticalAlignment="Center" Margin="0,0,5,0" LostFocus="CompoundEdit_LostFocus" />
                                                <TextBox Text="{Binding Abbreviation, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalAlignment="Center" Margin="0,0,5,0" LostFocus="CompoundEdit_LostFocus" />
                                                <TextBox Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" Width="80" VerticalAlignment="Center" Margin="0,0,5,0" LostFocus="CompoundEdit_LostFocus" ToolTip="Name or #HEX code" />
                                                <Border Width="20" Height="20" Background="{Binding BackgroundColor}" BorderBrush="Black" BorderThickness="1" Margin="0,0,10,0"/>
                                                <Button Content="Remove" Click="RemoveCompound_Click" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Tyre Property Overrides" Margin="0,0,0,10">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Overrides pull from alternate plugin data. Keep empty for default SimHub tyre data." Grid.ColumnSpan="2" Margin="0,0,0,10" FontStyle="Italic" TextWrapping="Wrap" />
                                
                                <TextBlock Text="Target Game:" Grid.Row="1" VerticalAlignment="Center" Margin="0,2"/>
                                <ComboBox Name="GameOverrideCombo" Grid.Row="1" Grid.Column="1" IsEditable="True" Margin="0,2,0,10" SelectionChanged="GameOverrideCombo_SelectionChanged" />

                                <TextBlock Text="Front Left:" Grid.Row="2" VerticalAlignment="Center" Margin="0,2"/>
                                <ComboBox Name="OverrideFL" Grid.Row="2" Grid.Column="1" IsEditable="True" Margin="0,2" />
                                
                                <TextBlock Text="Front Right:" Grid.Row="3" VerticalAlignment="Center" Margin="0,2"/>
                                <ComboBox Name="OverrideFR" Grid.Row="3" Grid.Column="1" IsEditable="True" Margin="0,2" />
                                
                                <TextBlock Text="Rear Left:" Grid.Row="4" VerticalAlignment="Center" Margin="0,2"/>
                                <ComboBox Name="OverrideRL" Grid.Row="4" Grid.Column="1" IsEditable="True" Margin="0,2" />
                                
                                <TextBlock Text="Rear Right:" Grid.Row="5" VerticalAlignment="Center" Margin="0,2"/>
                                <ComboBox Name="OverrideRR" Grid.Row="5" Grid.Column="1" IsEditable="True" Margin="0,2" />

                                <Button Content="Save Overrides" Click="SaveOverrides_Click" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left" Margin="0,5,0,0" Padding="15,0" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Data Management" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <Button Content="Backup All Settings..." Click="BackupRecords_Click" Padding="15,5" Margin="0,0,10,0"/>
                                <Button Content="Restore All Settings..." Click="RestoreRecords_Click" Padding="15,5" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
